<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_loyalty_card_list" model="ir.ui.view">
        <field name="name">pos.loyalty.card.list</field>
        <field name="model">pos.loyalty.card</field>
        <field name="arch" type="xml">
            <list string="Loyalty Cards">
                <field name="code"/>
                <field name="partner_id"/>
                <field name="points"/>
            </list>
        </field>
    </record>

    <record id="view_loyalty_card_form" model="ir.ui.view">
        <field name="name">pos.loyalty.card.form</field>
        <field name="model">pos.loyalty.card</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="partner_id"/>
                        <field name="points"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loyalty_cards" model="ir.actions.act_window">
        <field name="name">Loyalty Cards</field>
        <field name="res_model">pos.loyalty.card</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_loyalty_root" name="Loyalty"
              sequence="50" parent="point_of_sale.menu_point_root"/>
    <menuitem id="menu_loyalty_cards" name="Loyalty Cards"
              action="action_loyalty_cards" parent="menu_loyalty_root"/>
</odoo>
