<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
  <t t-name="pos_discount_loyalty.LoyaltyPopup">
    <Dialog title="'Member Lookup'" footer="false">
      <div class="p-4 w-100">
        <h4 class="mb-3">Member Lookup</h4>

        <div class="d-flex gap-2 my-3">
          <input
              type="text"
              class="form-control"
              t-model="state.code"
          />
          <button class="btn btn-primary" t-on-click="search">Search</button>
        </div>
        <t t-if="state.error">
          <p class="text-danger small"><t t-esc="state.error"/></p>
        </t>
        <t t-if="state.member">
          <div class="border rounded p-3 bg-light">
            <strong class="d-block mb-1"><t t-esc="state.member.name"/></strong>
            <div class="mt-2">
                <div>Points: <t t-esc="state.member.points"/></div>
                <div>Discount: <t t-esc="state.member.discount"/>%</div>
            </div>
          </div>
        </t>

        <div class="d-flex justify-content-end gap-2 mt-4">
          <button class="btn btn-secondary" t-on-click="() => props.close()">Cancel</button>
          <button class="btn btn-primary" t-att-disabled="!state.member" t-on-click="confirm">Apply</button>
        </div>
      </div>
    </Dialog>
  </t>

  <t t-name="pos_discount_loyalty.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
    <xpath expr="//button[contains(@class, 'more-btn')]" position="before">
      <button class="btn btn-light btn-lg lh-lg" t-on-click="onClickLoyalty">
        Loyalty
      </button>
    </xpath>
  </t>
</templates>